tran 0.01n 100n
 plot v(a0) v(a1)+2 v(a2)+4 v(a3)+6 v(a4)+8 
 plot v(b0) v(b1)+2 v(b2)+4 v(b3)+6 v(b4)+8 
 plot v(s0) v(s1)+2 v(s2)+4 v(s3)+6 v(s4)+8 
 plot v(c5)



meas tran t_b0_50_rise  WHEN v(b0)=0.9 RISE=1
meas tran t_cout_50_rise  WHEN v(c5)=0.9 RISE=1

meas tran t_b0_50_fall  WHEN v(b0)=0.9 FALL=1
meas tran t_cout_50_fall  WHEN v(c5)=0.9 FALL=1


let Rise_delay  = t_cout_50_rise - t_b0_50_rise
let Fall_delay  = t_cout_50_fall - t_b0_50_fall 

print Rise_delay
print FALL_delay

run
.endc

.end

