**5-bit Carry Lookahead Adder
.include TSMC_180nm.txt
.param SUPPLY=1.8
.global gnd vdd
.param LAMBDA=0.09u
.param width_N=0.9u
.param width_P=2*width_N

VDD vdd gnd 1.8

*  Va0 a0 gnd PULSE(0 1.8 0 0.1n 0.1n 50n 100n)
*  Va1 a1 gnd PULSE(0 1.8 0 0.1n 0.1n 50n 100n)
*  Va2 a2 gnd PULSE(0 1.8 0 0.1n 0.1n 50n 100n)
*  Va3 a3 gnd PULSE(0 1.8 0 0.1n 0.1n 50n 100n)
*  Va4 a4 gnd PULSE(0 1.8 0 0.1n 0.1n 50n 100n)

*  Vb0 b0 gnd PULSE(0 1.8 0 0.1n 0.1n 50n 100n)
*  Vb1 b1 gnd PULSE(0 1.8 0 0.1n 0.1n 50n 100n)
*  Vb2 b2 gnd PULSE(0 1.8 0 0.1n 0.1n 50n 100n)
*  Vb3 b3 gnd PULSE(0 1.8 0 0.1n 0.1n 50n 100n)
*  Vb4 b4 gnd PULSE(0 1.8 0 0.1n 0.1n 50n 100n)

Va0 a0 gnd 1.8
Va1 a1 gnd 1.8
Va2 a2 gnd 1.8
Va3 a3 gnd 1.8
Va4 a4 gnd 1.8

Vb0 b0 gnd PULSE(0 1.8 0 0.1n 0.1n 50n 100n)
Vb1 b1 gnd 0
Vb2 b2 gnd 0
Vb3 b3 gnd 0
Vb4 b4 gnd 0

.option scale=0.09u

